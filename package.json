{
  "name": "@framers/agentos-extensions-registry",
  "version": "0.12.0",
  "files": [
    "dist",
    "README.md"
  ],
  "description": "Extension catalog for AgentOS — channel, tool, and provider metadata with dynamic loading via createCuratedManifest()",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./channels": {
      "import": "./dist/channel-registry.js",
      "types": "./dist/channel-registry.d.ts"
    },
    "./providers": {
      "import": "./dist/provider-registry.js",
      "types": "./dist/provider-registry.d.ts"
    },
    "./tools": {
      "import": "./dist/tool-registry.js",
      "types": "./dist/tool-registry.d.ts"
    },
    "./types": {
      "import": "./dist/types.js",
      "types": "./dist/types.d.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "vitest run --testTimeout 60000"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/framersai/agentos-extensions-registry.git"
  },
  "keywords": [
    "agentos",
    "extensions",
    "registry",
    "channels",
    "tools"
  ],
  "author": {
    "name": "Framers AI",
    "email": "team@frame.dev",
    "url": "https://frame.dev"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@framers/agentos": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "@framers/agentos": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "@framers/agentos-ext-auth": "^1.1.0",
    "@framers/agentos-ext-web-search": "^1.1.1",
    "@framers/agentos-ext-web-browser": "^1.2.1",
    "@framers/agentos-ext-telegram": "^1.1.0",
    "@framers/agentos-ext-cli-executor": "^1.2.0",
    "@framers/agentos-ext-giphy": "^1.0.0",
    "@framers/agentos-ext-image-search": "^1.0.0",
    "@framers/agentos-ext-voice-synthesis": "^2.0.0",
    "@framers/agentos-ext-news-search": "^1.0.0",
    "@framers/agentos-ext-weather": "^1.0.0",
    "@framers/agentos-ext-streaming-stt-deepgram": ">=0.1.0",
    "@framers/agentos-ext-streaming-stt-whisper": ">=0.1.0",
    "@framers/agentos-ext-streaming-tts-openai": ">=0.1.0",
    "@framers/agentos-ext-streaming-tts-elevenlabs": ">=0.1.0",
    "@framers/agentos-ext-diarization": ">=0.1.0",
    "@framers/agentos-ext-endpoint-semantic": ">=0.1.0",
    "@framers/agentos-ext-google-cloud-stt": ">=0.1.0",
    "@framers/agentos-ext-google-cloud-tts": ">=0.1.0",
    "@framers/agentos-ext-amazon-polly": ">=0.1.0",
    "@framers/agentos-ext-vosk": ">=0.1.0",
    "@framers/agentos-ext-piper": ">=0.1.0",
    "@framers/agentos-ext-porcupine": ">=0.1.0",
    "@framers/agentos-ext-openwakeword": ">=0.1.0",
    "@framers/agentos-ext-pii-redaction": ">=0.1.0",
    "@framers/agentos-ext-ml-classifiers": ">=0.1.0",
    "@framers/agentos-ext-topicality": ">=0.1.0",
    "@framers/agentos-ext-code-safety": ">=0.1.0",
    "@framers/agentos-ext-grounding-guard": ">=0.1.0"
  },
  "devDependencies": {
    "@framers/agentos": "^0.1.80",
    "typescript": "^5.4.5",
    "vitest": "^1.0.0"
  }
}
