{
  "name": "@framers/agentos-extensions-registry",
  "version": "0.17.0",
  "files": [
    "dist",
    "README.md"
  ],
  "description": "Extension catalog for AgentOS \u2014 channel, tool, and provider metadata with dynamic loading via createCuratedManifest()",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./channels": {
      "import": "./dist/channel-registry.js",
      "default": "./dist/channel-registry.js",
      "types": "./dist/channel-registry.d.ts"
    },
    "./providers": {
      "import": "./dist/provider-registry.js",
      "default": "./dist/provider-registry.js",
      "types": "./dist/provider-registry.d.ts"
    },
    "./tools": {
      "import": "./dist/tool-registry.js",
      "default": "./dist/tool-registry.js",
      "types": "./dist/tool-registry.d.ts"
    },
    "./types": {
      "import": "./dist/types.js",
      "default": "./dist/types.js",
      "types": "./dist/types.d.ts"
    },
    "./capability-catalog": {
      "import": "./dist/capability-catalog.js",
      "default": "./dist/capability-catalog.js",
      "types": "./dist/capability-catalog.d.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "prebuild": "node scripts/generate-capability-catalog.mjs",
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "vitest run --testTimeout 60000"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/framersai/agentos-extensions-registry.git"
  },
  "keywords": [
    "agentos",
    "extensions",
    "registry",
    "channels",
    "tools"
  ],
  "author": {
    "name": "Framers AI",
    "email": "team@frame.dev",
    "url": "https://frame.dev"
  },
  "license": "Apache-2.0",
